rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura pública de productos y categorías
    match /productos/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /categorias/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /configuracion/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /informacion/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Resto de documentos solo para usuarios autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}